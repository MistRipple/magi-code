+  '你和 gemini',
+  'who are you',
+  'what are you',
+  'what can you do',
+  'how to use',
+  'capabilities',
+  'your role',
+];
+const CONVERSATIONAL_KEYWORDS = [
+  '你好',
+  'hello',
+  'hi',
+  'thanks',
+  'thank you',
+  '谢谢',
+  '早上好',
+  '晚上好',
+];
+
+function includesAny(prompt: string, keywords: string[]): boolean {
+  return keywords.some((keyword) => prompt.includes(keyword));
+}
+
+export function classifyRequest(prompt: string, mode: PlanMode): RequestClassification {
+  const normalizedPrompt = prompt.toLowerCase();
+  const hasReadOnlyIntent = includesAny(normalizedPrompt, READ_ONLY_KEYWORDS);
+  const hasWriteIntent = includesAny(normalizedPrompt, WRITE_KEYWORDS);
+  const hasHighImpactIntent = includesAny(normalizedPrompt, HIGH_IMPACT_KEYWORDS);
+  const hasWorkspaceScopedIntent = includesAny(normalizedPrompt, WORKSPACE_SCOPED_KEYWORDS);
+  const hasAssistantMetaIntent = includesAny(normalizedPrompt, ASSISTANT_META_KEYWORDS);
+  const hasConversationalIntent = includesAny(normalizedPrompt, CONVERSATIONAL_KEYWORDS)
+    || /[?？吗么]/.test(prompt);
+  const isShortConversationalTurn = prompt.trim().length <= 120;
+  const requiresModification = hasWriteIntent || hasHighImpactIntent;
+
+  const requestKind: RequestKind = !requiresModification
+    && !hasWorkspaceScopedIntent
+    && isShortConversationalTurn
+    && (hasAssistantMetaIntent || hasConversationalIntent)
+    ? 'direct_response'
+    : !requiresModification && hasReadOnlyIntent
+    ? 'analysis'
+    : 'task_execution';
+
+  const needsWorker = requestKind === 'direct_response'
+    ? false
+    : mode === 'deep' || requiresModification || !hasReadOnlyIntent;
+  const needsTooling = requestKind === 'direct_response'
+    ? false
+    : mode === 'deep' || requiresModification;
+
+  return {
+    requestKind,
+    hasReadOnlyIntent,
+    hasWriteIntent,
+    hasHighImpactIntent,
+    hasWorkspaceScopedIntent,
+    hasAssistantMetaIntent,
+    hasConversationalIntent,
+    isShortConversationalTurn,
+    needsWorker,
+    needsTooling,
+    requiresModification,
+    reason: requestKind === 'direct_response'
+      ? '请求属于非任务型直接问答，应走轻量直答路径，避免编排历史、项目上下文和内部工具污染主线'
+      : requestKind === 'analysis'
+      ? '请求以只读分析为主，可优先保持轻量分析链路，不触发写入型任务编排'
+      : '请求已进入任务执行语义，需要继续完成计划生成与后续调度决策',
+  };
+}
