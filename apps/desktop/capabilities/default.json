{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Main Magi window permissions",
  "remote": {
    "urls": [
      "http://127.0.0.1:*",
      "http://localhost:*"
    ]
  },
  "windows": ["main"],
  "permissions": [
    "core:default",
    "process:default",
    "updater:default",
    "allow-prepare-update-restart",
    "allow-get-staged-desktop-update",
    "allow-get-desktop-update-installability",
    "allow-stage-desktop-update",
    "allow-install-staged-desktop-update"
  ]
}
