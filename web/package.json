{
  "name": "magi-web",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node -e \"console.error('请使用 MAGI_WEB_DEV=1 cargo run -p magi-daemon-app，并访问 http://127.0.0.1:38123/web.html'); process.exit(1)\"",
    "dev:rust": "node -e \"console.error('请使用 MAGI_WEB_DEV=1 cargo run -p magi-daemon-app，并访问 http://127.0.0.1:38123/web.html'); process.exit(1)\"",
    "dev:daemon": "vite --config vite.web.config.ts",
    "build": "vite build --config vite.web.config.ts",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "npm run test:canonical && npm run test:transport && npm run test:agent-api && npm run test:right-pane && npm run test:file-reference && npm run test:panel-layout && npm run test:agent-run && npm run test:active-agent-center && npm run test:workspace-onboarding && npm run test:goal && npm run test:slash-command && npm run test:tool-error && npm run test:tool-call-display && npm run test:context-ring && npm run test:runtime-state && npm run test:notification-policy && npm run test:notification-runtime && npm run test:mermaid-source && npm run test:tool-catalog && npm run test:bridge",
    "test:agent-api": "node scripts/agent-api-golden.mjs",
    "test:bridge": "node scripts/web-client-bridge-golden.mjs",
    "test:canonical": "node scripts/canonical-turn-golden.mjs",
    "test:right-pane": "node scripts/right-pane-golden.mjs",
    "test:file-reference": "node scripts/file-reference-golden.mjs",
    "test:panel-layout": "node scripts/panel-layout-golden.mjs",
    "test:agent-run": "node scripts/agent-run-store-golden.mjs",
    "test:active-agent-center": "node scripts/active-agent-center-golden.mjs",
    "test:workspace-onboarding": "node scripts/workspace-onboarding-golden.mjs",
    "test:goal": "node scripts/goal-store-golden.mjs",
    "test:slash-command": "node scripts/slash-command-golden.mjs",
    "test:tool-call-display": "node scripts/tool-call-display-golden.mjs",
    "test:context-ring": "node scripts/context-usage-ring-golden.mjs",
    "test:runtime-state": "node scripts/runtime-state-panel-golden.mjs",
    "test:notification-policy": "node scripts/notification-policy-golden.mjs",
    "test:notification-runtime": "node scripts/notification-runtime-golden.mjs",
    "test:mermaid-source": "node scripts/mermaid-source-golden.mjs",
    "test:tool-catalog": "node scripts/tool-catalog-normalization-golden.mjs",
    "test:tool-error": "node scripts/tool-error-payload-golden.mjs",
    "test:transport": "node scripts/live-transport-golden.mjs"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tsconfig/svelte": "^5.0.4",
    "svelte": "^5.56.4",
    "svelte-check": "^4.2.1",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "dependencies": {
    "@humanspeak/svelte-markdown": "^1.7.10",
    "@types/qrcode": "^1.5.6",
    "@viz-js/viz": "^3.26.0",
    "@xyflow/svelte": "^1.5.2",
    "cytoscape": "^3.33.3",
    "cytoscape-cose-bilkent": "^4.1.0",
    "cytoscape-fcose": "^2.2.0",
    "highlight.js": "^11.11.1",
    "mermaid": "^11.16.0",
    "qrcode": "^1.5.4"
  }
