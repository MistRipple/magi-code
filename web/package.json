{
  "name": "magi-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node -e \"console.error('请使用 MAGI_WEB_DEV=1 cargo run -p magi-daemon-app，并访问 http://127.0.0.1:38123/web.html'); process.exit(1)\"",
    "dev:rust": "node -e \"console.error('请使用 MAGI_WEB_DEV=1 cargo run -p magi-daemon-app，并访问 http://127.0.0.1:38123/web.html'); process.exit(1)\"",
    "dev:daemon": "vite --config vite.web.config.ts",
    "build": "vite build --config vite.web.config.ts",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "npm run test:canonical && npm run test:transport && npm run test:agent-api && npm run test:bridge",
    "test:agent-api": "node scripts/agent-api-golden.mjs",
    "test:bridge": "node scripts/web-client-bridge-golden.mjs",
    "test:canonical": "node scripts/canonical-turn-golden.mjs",
    "test:transport": "node scripts/live-transport-golden.mjs"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tsconfig/svelte": "^5.0.4",
    "svelte": "^5.33.0",
    "svelte-check": "^4.2.1",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "dependencies": {
    "@humanspeak/svelte-markdown": "^1.2.0",
    "@types/qrcode": "^1.5.6",
    "@viz-js/viz": "^3.26.0",
    "@xyflow/svelte": "^1.5.2",
    "cytoscape": "^3.33.3",
    "cytoscape-cose-bilkent": "^4.1.0",
    "cytoscape-fcose": "^2.2.0",
    "highlight.js": "^11.11.1",
    "mermaid": "^11.12.2",
    "qrcode": "^1.5.4"
  }
}
